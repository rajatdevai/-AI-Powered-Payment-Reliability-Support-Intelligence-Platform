{
  "name": "@prism/payment-orchestrator",
  "version": "1.0.0",
  "description": "PRISM Payment Orchestrator — Fastify + Kafka + gRPC",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:seed": "ts-node src/seed/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "@prisma/client": "^5.16.2",
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.16.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
