# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/prism_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# Kafka (set ENABLE_KAFKA=false to run without Kafka)
KAFKA_BROKERS="localhost:9092"
ENABLE_KAFKA="false"

# gRPC — prediction-engine address
PREDICTION_ENGINE_GRPC_ADDR="localhost:50051"
ENABLE_GRPC="false"

# Server
PORT="3010"
NODE_ENV="development"
LOG_LEVEL="info"
